LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Render Postgres（或相容 PostgreSQL）連線字串。
# 建議：與 Web Service 同區時用 Internal Database URL；本機／外部工具可用 External Database URL。
# 若設定，對話記憶／收藏／菜系情境會優先走 PostgreSQL（見 init_db.py、docs/RENDER_POSTGRES.md）。
DATABASE_URL=
SUPABASE_URL=
SUPABASE_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
YOUTUBE_API_KEY=
IMAGE_PROVIDER=placeholder
GCP_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_IMAGEN_MODEL=imagen-3.0-generate-002
# 可選：直接放 Service Account JSON（單行字串）；未設則走 GOOGLE_APPLICATION_CREDENTIALS / ADC
VERTEX_SERVICE_ACCOUNT_JSON=
# 可選：輸出到 GCS（gs://bucket/prefix），若 bucket 公開可直接轉為 https URL
VERTEX_IMAGEN_OUTPUT_GCS_URI=
# 食譜主圖 in-memory 快取秒數（vertex_imagen / openai_compatible）；0 關閉
IMAGE_CACHE_TTL_SEC=300
MODEL_NAME=gemini-3.1-flash-lite-preview
DEBUG=1
DEFAULT_TENANT_ID=default
PLAN_FREE_DAILY_LIMIT=20
PLAN_PRO_DAILY_LIMIT=200
PLAN_ENTERPRISE_DAILY_LIMIT=2000
QUEUE_WORKER_COUNT=2
QUEUE_MAX_SIZE=1000
QUEUE_DEDUPE_TTL_SEC=900
REQUIRE_ATOMIC_USAGE=0
BILLING_PROVIDER=manual
CHECKOUT_URL_TEMPLATE=
BILLING_BASE_URL=https://example.com
ADMIN_API_TOKEN=
METRICS_TOKEN=
