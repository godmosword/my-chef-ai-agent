LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Render Postgres（或相容 PostgreSQL）連線字串。
# 建議：與 Web Service 同區時用 Internal Database URL；本機／外部工具可用 External Database URL。
# 若設定，對話記憶／收藏／菜系情境／配額會走 PostgreSQL（見 init_db.py、migrations/）。
DATABASE_URL=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
YOUTUBE_API_KEY=
# 食譜主圖：placeholder（備援圖）／vertex_imagen（Vertex SDK Imagen）／openai_compatible（DALL-E 3）
IMAGE_PROVIDER=placeholder
GCP_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_IMAGEN_MODEL=imagen-3.0-generate-002
# 可選：直接放 Service Account JSON（單行字串）；未設則走 GOOGLE_APPLICATION_CREDENTIALS / ADC
VERTEX_SERVICE_ACCOUNT_JSON=
# 可選：與上一項擇一；啟動時寫入暫存檔並設定 GOOGLE_APPLICATION_CREDENTIALS（適合 Render／Cloud Run 單一密文）
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# 可選：輸出到 GCS（gs://bucket/prefix），若 bucket 公開可直接轉為 https URL
VERTEX_IMAGEN_OUTPUT_GCS_URI=
# 可選：當 image URL 需要固定公開網域時可設定，如 https://cdn.example.com/images
IMAGE_PUBLIC_BASE_URL=
# 食譜主圖 in-memory 快取秒數（vertex_imagen / openai_compatible）；0 關閉
IMAGE_CACHE_TTL_SEC=300
# 圖片快取後端：auto / memory / redis
IMAGE_CACHE_BACKEND=auto
# 可選：跨實例圖片快取（Redis / Upstash）
REDIS_URL=
IMAGE_CACHE_NAMESPACE=recipe_image
# GCS 簽名 URL 有效秒數（Vertex 輸出 gs:// 且 bucket 非公開時需要）；0 關閉簽名
GCS_SIGNED_URL_TTL_SEC=3600
# 無 AI 主圖時 Flex hero 使用的公開 https 圖；設為 none 關閉（僅顯示色塊標題）
# RECIPE_FALLBACK_HERO_IMAGE_URL=
# AI 傳輸層：429／逾時／連線失敗時額外重試次數與起始退避（秒）
AI_TRANSPORT_MAX_RETRIES=3
AI_TRANSPORT_BASE_DELAY_SEC=0.5
# 每 IP 每分鐘：LINE webhook、公開 checkout／legal；0 關閉該限制
RATE_LIMIT_CALLBACK_PER_MINUTE=120
RATE_LIMIT_PUBLIC_PER_MINUTE=90
RATE_LIMIT_USER_PER_MINUTE=30
RATE_LIMIT_USER_BURST=5
# 接近額度時提醒門檻
QUOTA_WARN_THRESHOLD=3
MODEL_NAME=gemini-3.1-flash-lite-preview
# 食譜 JSON 較長：過小易截斷成不合法 JSON（LINE 會顯示 fallback）。預設 4096。
MAX_COMPLETION_TOKENS=4096
# JSON 解析失敗時額外重試次數（不含首次）；含截斷修復 prompt。預設 2。
AI_MAX_RETRIES=2
RECIPE_STEPS_PREVIEW_COUNT=3
RECIPE_STEPS_MAX_COUNT=6
RECIPE_STEP_MAX_CHARS=24
DEBUG=1
DEFAULT_TENANT_ID=default
PLAN_FREE_DAILY_LIMIT=20
PLAN_PRO_DAILY_LIMIT=200
PLAN_ENTERPRISE_DAILY_LIMIT=2000
QUEUE_WORKER_COUNT=2
QUEUE_MAX_SIZE=1000
QUEUE_DEDUPE_TTL_SEC=900
REQUIRE_ATOMIC_USAGE=0
BILLING_PROVIDER=manual
CHECKOUT_URL_TEMPLATE=
BILLING_BASE_URL=https://example.com
# 對外 https 基底（legal URI、Vertex 無 GCS 時食譜主圖 /media/recipe-hero/{token}）
PUBLIC_APP_BASE_URL=
ADMIN_API_TOKEN=
METRICS_TOKEN=
LOG_USER_HASH_SALT=local-dev-salt
OTEL_ENABLED=0
OTEL_SERVICE_NAME=my-chef-ai-agent
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLING_RATIO=1.0
