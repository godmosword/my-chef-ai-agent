
# =============================================================================
# .cursorignore — Universal Context Budget Guard
# 目的：嚴控 Cursor Agent 的 context token 消耗，適用所有專案類型
# 原則：只讓 AI 看「需要改動的程式碼」，其餘一律排除
# =============================================================================


# ── 版本控制 ─────────────────────────────────────────────────────────────────
.git/
.hg/
.svn/
.github/
.gitlab/


# ── 依賴目錄（最大 token 殺手）──────────────────────────────────────────────
node_modules/
bower_components/
.pnp/
.venv/
venv/
env/
ENV/
site-packages/
*.egg-info/
vendor/
vendor/bundle/
.bundle/
target/
.gradle/
.mvn/


# ── Lock 檔（單檔可達數萬行，AI 絕對不該動）─────────────────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
poetry.lock
Pipfile.lock
Gemfile.lock
Cargo.lock
composer.lock
go.sum


# ── 建置產物 ─────────────────────────────────────────────────────────────────
dist/
build/
out/
output/
bin/
obj/
.next/
.nuxt/
.svelte-kit/
.vite/
.turbo/
.parcel-cache/
.cache/
.serverless/
.vercel/
.terraform/
storybook-static/
*.min.js
*.min.css
*.bundle.js
*.chunk.js


# ── 編譯 / 快取檔 ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.class
*.jar
*.war
*.tfstate
*.tfstate.backup


# ── 測試 / 覆蓋率報告 ────────────────────────────────────────────────────────
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
test-results/
junit*.xml
*.lcov


# ── 環境變數 / 密鑰 ──────────────────────────────────────────────────────────
.env
.env.*
**/.env
**/.env.*
*.pem
*.key
*.pub
*.p12
*.pfx
secrets/
credentials/


# ── Log / 暫存 ──────────────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
.temp/
*.tmp
*.bak
*.swp
*.swo
~$*


# ── 資料檔（量化資料與 Agent Log）──────────────────────────────────────────
*.csv
*.tsv
*.jsonl
*.parquet
*.feather
*.sqlite
*.sqlite3
*.db
*.h5
*.hdf5
*.pkl
data/
datasets/
raw_data/


# ── 媒體 / 二進位 ────────────────────────────────────────────────────────────
# 圖片
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.webp
*.bmp
*.tiff

# 影音
*.mp4
*.mp3
*.mov
*.avi
*.wav

# 字型
*.woff
*.woff2
*.ttf
*.eot
*.otf

# 文件 / 壓縮
*.pdf
*.zip
*.tar.gz
*.rar
*.7z
*.dmg
*.exe
*.dll
*.so
*.dylib


# ── Notebook（output cell 是 token 炸彈）────────────────────────────────────
*.ipynb


# ── IDE / 工具快取 ──────────────────────────────────────────────────────────
.vscode/
.idea/
.cursor/
*.iml
.DS_Store
Thumbs.db
*.suo
*.user


# ── 半導體 / EDA 專案（Chipbond 環境）───────────────────────────────────────
# 光罩 / 版圖
*.gds
*.gds2
*.oas
*.oasis
*.lef
*.def

# 模擬 / 驗證輸出
*.sim
simulations/
results/
*.rdb
*.svdb
drc_results/
lvs_results/


# ── AI / ML 模型權重 ────────────────────────────────────────────────────────
*.pt
*.pth
*.ckpt
*.safetensors
*.gguf
*.bin
models/
checkpoints/
weights/
